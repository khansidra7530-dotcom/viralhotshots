generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Niche {
  FINANCE
  TECH
  AI
  HEALTH
  GAMING
  CRYPTO
  BUSINESS
  TRAVEL
}

enum ArticleStatus {
  DRAFT
  PENDING
  PUBLISHED
  SCHEDULED
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum TrendSource {
  GOOGLE_TRENDS
  GOOGLE_NEWS
  REDDIT
  HACKER_NEWS
  PRODUCT_HUNT
  TWITTER
}

enum SocialPlatform {
  TWITTER
  THREADS
  LINKEDIN
  REDDIT
  FACEBOOK
}

enum SocialPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum MarketingRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  name                 String
  passwordHash         String
  role                 UserRole               @default(CUSTOMER)
  bio                  String?
  avatar               String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  articles             Article[]
  articleLikes         ArticleLike[]
  articleSubscriptions ArticleSubscription[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  niche       Niche
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]
}

model Article {
  id                   String        @id @default(cuid())
  title                String
  slug                 String        @unique
  excerpt              String
  content              String        @db.Text
  metaDescription      String
  featuredImage        String?
  featuredImagePrompt  String?
  status               ArticleStatus @default(PENDING)
  publishedAt          DateTime?
  scheduledAt          DateTime?
  readingTimeMinutes   Int           @default(5)
  viewCount            Int           @default(0)
  seoScore             Int           @default(0)
  tags                 String[]
  faq                  Json?
  internalLinks        Json?
  sources              Json?
  affiliateBlocks      Json?
  isAiGenerated        Boolean       @default(false)
  facebookPostId       String?
  primaryKeyword       String?
  lastOptimizedAt      DateTime?
  categoryId           String
  category             Category      @relation(fields: [categoryId], references: [id])
  authorId             String
  author               User          @relation(fields: [authorId], references: [id])
  comments             Comment[]
  likes                ArticleLike[]
  subscriptions        ArticleSubscription[]
  socialPosts          SocialPost[]
  trendCandidate       TrendCandidate?
  metricDaily          ArticleMetricDaily[]
  optimizationRuns     ArticleOptimizationRun[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
}

model ArticleLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@index([articleId])
}

model ArticleSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@index([articleId])
}

model AffiliateLink {
  id          String   @id @default(cuid())
  name        String
  url         String
  network     String   @default("custom")
  asin        String?
  niche       Niche?
  isActive    Boolean  @default(true)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  name      String
  email     String
  content   String   @db.Text
  approved  Boolean  @default(false)
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([articleId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SiteSettings {
  id                  String   @id @default("default")
  siteName            String   @default("InsightPress")
  siteUrl             String   @default("http://localhost:3000")
  siteDescription     String   @default("Expert guides, reviews, and insights")
  defaultNiche        Niche    @default(TECH)
  autoPublish         Boolean  @default(false)
  cronEnabled         Boolean  @default(true)
  marketingEnabled    Boolean  @default(true)
  autoSocialEnabled   Boolean  @default(true)
  autoOptimizeEnabled Boolean  @default(true)
  preferredLlm        String   @default("groq")
  n8nWebhookUrl       String?
  amazonAssociateTag  String?
  adsenseClientId     String?
  aiModel             String   @default("llama-3.3-70b-versatile") @map("openaiModel")
  updatedAt           DateTime @updatedAt
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  path      String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}

model CronLog {
  id        String   @id @default(cuid())
  job       String
  status    String
  message   String?
  articleId String?
  createdAt DateTime @default(now())

  @@index([job, createdAt])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
}

model MarketingResearchRun {
  id          String               @id @default(cuid())
  agentType   String
  status      MarketingRunStatus   @default(PENDING)
  summary     Json?
  error       String?
  startedAt   DateTime             @default(now())
  completedAt DateTime?
  candidates  TrendCandidate[]

  @@index([agentType, startedAt])
}

model TrendCandidate {
  id                String               @id @default(cuid())
  query             String
  title             String
  summary           String?              @db.Text
  source            TrendSource
  niche             Niche?
  trafficScore      Float                @default(0)
  competitionScore  Float                @default(0)
  viralScore        Float                @default(0)
  overallScore      Float                @default(0)
  keywords          String[]
  metadata          Json?
  researchRunId     String
  researchRun       MarketingResearchRun @relation(fields: [researchRunId], references: [id], onDelete: Cascade)
  articleId         String?              @unique
  article           Article?             @relation(fields: [articleId], references: [id])
  createdAt         DateTime             @default(now())

  @@index([overallScore])
  @@index([researchRunId])
}

model SocialPost {
  id          String           @id @default(cuid())
  articleId   String?
  article     Article?         @relation(fields: [articleId], references: [id], onDelete: SetNull)
  platform    SocialPlatform
  content     String           @db.Text
  threadParts Json?
  status      SocialPostStatus @default(DRAFT)
  scheduledAt DateTime?
  publishedAt DateTime?
  externalId  String?
  engagement  Json?
  error       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, scheduledAt])
  @@index([articleId])
  @@index([platform, status])
}

model ArticleMetricDaily {
  id           String   @id @default(cuid())
  articleId    String
  article      Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  views        Int      @default(0)
  likes        Int      @default(0)
  socialClicks Int      @default(0)
  seoScore     Int?

  @@unique([articleId, date])
  @@index([date])
}

model ArticleOptimizationRun {
  id          String             @id @default(cuid())
  articleId   String
  article     Article            @relation(fields: [articleId], references: [id], onDelete: Cascade)
  agentType   String
  beforeScore Int?
  afterScore  Int?
  changes     Json?
  status      MarketingRunStatus @default(PENDING)
  error       String?
  createdAt   DateTime           @default(now())

  @@index([articleId, createdAt])
}
