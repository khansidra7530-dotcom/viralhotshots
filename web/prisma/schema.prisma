generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Niche {
  FINANCE
  TECH
  AI
  HEALTH
  GAMING
  CRYPTO
  BUSINESS
  TRAVEL
}

enum ArticleStatus {
  DRAFT
  PENDING
  PUBLISHED
  SCHEDULED
}

enum UserRole {
  ADMIN
  EDITOR
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole  @default(ADMIN)
  bio          String?
  avatar       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  articles     Article[]
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  niche       Niche
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]
}

model Article {
  id                   String        @id @default(cuid())
  title                String
  slug                 String        @unique
  excerpt              String
  content              String        @db.Text
  metaDescription      String
  featuredImage        String?
  featuredImagePrompt  String?
  status               ArticleStatus @default(PENDING)
  publishedAt          DateTime?
  scheduledAt          DateTime?
  readingTimeMinutes   Int           @default(5)
  viewCount            Int           @default(0)
  seoScore             Int           @default(0)
  tags                 String[]
  faq                  Json?
  internalLinks        Json?
  sources              Json?
  affiliateBlocks      Json?
  isAiGenerated        Boolean       @default(false)
  categoryId           String
  category             Category      @relation(fields: [categoryId], references: [id])
  authorId             String
  author               User          @relation(fields: [authorId], references: [id])
  comments             Comment[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
}

model AffiliateLink {
  id          String   @id @default(cuid())
  name        String
  url         String
  network     String   @default("custom")
  asin        String?
  niche       Niche?
  isActive    Boolean  @default(true)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  name      String
  email     String
  content   String   @db.Text
  approved  Boolean  @default(false)
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([articleId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SiteSettings {
  id                  String   @id @default("default")
  siteName            String   @default("InsightPress")
  siteUrl             String   @default("http://localhost:3000")
  siteDescription     String   @default("Expert guides, reviews, and insights")
  defaultNiche        Niche    @default(TECH)
  autoPublish         Boolean  @default(false)
  cronEnabled         Boolean  @default(true)
  amazonAssociateTag  String?
  adsenseClientId     String?
  openaiModel         String   @default("gpt-4o-mini")
  updatedAt           DateTime @updatedAt
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  path      String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}

model CronLog {
  id        String   @id @default(cuid())
  job       String
  status    String
  message   String?
  articleId String?
  createdAt DateTime @default(now())

  @@index([job, createdAt])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
}
