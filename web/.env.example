# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/insightpress"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Site
NEXT_PUBLIC_SITE_NAME="InsightPress"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# OpenAI (required for AI article generation)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Unsplash hero images (optional — free key at unsplash.com/developers)
UNSPLASH_ACCESS_KEY=""

# Cron (Vercel Cron + manual triggers)
CRON_SECRET="your-secure-random-string"

# Admin seed credentials
ADMIN_EMAIL="admin@insightpress.com"
ADMIN_PASSWORD="ChangeMe123!"

# Affiliate
AMAZON_ASSOCIATE_TAG="yourtag-20"

# AdSense (optional)
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-xxxxxxxx"
