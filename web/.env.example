# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/insightpress"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Site
NEXT_PUBLIC_SITE_NAME="InsightPress"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Google Analytics 4 — measurement ID from analytics.google.com (Admin → Data streams)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Facebook Page auto-post (Meta Graph API) — https://developers.facebook.com/
# Graph API Page ID (not profile.php id) — run: npx tsx scripts/facebook-page-token.ts
FACEBOOK_PAGE_ID="571859719347744"
FACEBOOK_PAGE_ACCESS_TOKEN=""
# Set to false to disable auto-posting without removing the token
FACEBOOK_PUBLISH_ENABLED="true"
NEXT_PUBLIC_SOCIAL_FACEBOOK="https://www.facebook.com/profile.php?id=61573902383633"

# Groq AI — free at https://console.groq.com/keys
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"

# Unsplash hero images (optional — free key at unsplash.com/developers)
UNSPLASH_ACCESS_KEY=""

# Cron (Vercel Cron + manual triggers)
CRON_SECRET="your-secure-random-string"

# Admin seed credentials
ADMIN_EMAIL="admin@insightpress.com"
ADMIN_PASSWORD="ChangeMe123!"

# Affiliate
AMAZON_ASSOCIATE_TAG="yourtag-20"

# AdSense (optional)
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-xxxxxxxx"
