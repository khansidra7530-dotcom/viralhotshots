# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/insightpress"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Site
NEXT_PUBLIC_SITE_NAME="InsightPress"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Google Analytics 4 — measurement ID from analytics.google.com (Admin → Data streams)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Search engine verification (meta tags — paste content value only, not full HTML tag)
# Google Search Console → HTML tag method
GOOGLE_SITE_VERIFICATION=""
# Bing Webmaster Tools → msvalidate.01 meta tag content value
BING_SITE_VERIFICATION=""

# IndexNow — instant Bing/Yandex indexing (generate: openssl rand -hex 16)
# Key file served at /indexnow-key.txt after deploy
INDEXNOW_KEY=""

# Public social profile links (footer / contact — not auto-posting)
NEXT_PUBLIC_SOCIAL_FACEBOOK="https://www.facebook.com/profile.php?id=61573902383633"

# Groq AI — free at https://console.groq.com/keys
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"

# Unsplash hero images (optional — free key at unsplash.com/developers)
UNSPLASH_ACCESS_KEY=""

# Cron (Vercel Cron + manual triggers)
CRON_SECRET="your-secure-random-string"

# Admin seed credentials
ADMIN_EMAIL="admin@insightpress.com"
ADMIN_PASSWORD="ChangeMe123!"

# Affiliate
AMAZON_ASSOCIATE_TAG="yourtag-20"

# AdSense (optional)
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-xxxxxxxx"
